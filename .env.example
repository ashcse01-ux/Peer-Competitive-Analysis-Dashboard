# =============================================================================
# FreshBus Competitor Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit the real .env file to version control.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Full PostgreSQL connection string used by the Python services (SQLAlchemy/asyncpg).
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:postgres@db:5432/competitordb

# Database name — used by the Docker Compose `db` service to initialise the cluster.
POSTGRES_DB=competitordb

# PostgreSQL username — must match the user in DATABASE_URL.
POSTGRES_USER=postgres

# PostgreSQL password — must match the password in DATABASE_URL.
# Use a strong, randomly generated value in production.
POSTGRES_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Scraper
# -----------------------------------------------------------------------------

# Comma-separated list of HTTP/HTTPS proxy URLs for request rotation.
# Leave blank to disable proxy rotation (scraper will use the host's IP directly).
# Example: http://proxy1:8080,http://proxy2:8080
PROXY_LIST=

# -----------------------------------------------------------------------------
# API / Admin
# -----------------------------------------------------------------------------

# Bearer token required to call POST /api/v1/refresh/trigger.
# Leave blank to disable authentication on that endpoint (MVP default).
# Example: super-secret-admin-token
ADMIN_TOKEN=

# Host address FastAPI binds to. Use 0.0.0.0 to accept connections from all
# interfaces (required inside Docker). Use 127.0.0.1 for local-only access.
API_HOST=0.0.0.0

# TCP port FastAPI listens on. The Docker Compose file maps this to the host.
API_PORT=8000

# -----------------------------------------------------------------------------
# NLP / Aggregator
# -----------------------------------------------------------------------------

# HuggingFace model identifier used by the sentiment engine.
# Changing this value triggers a full recomputation of all historical scores.
NLP_MODEL_NAME=cardiffnlp/twitter-xlm-roberta-base-sentiment

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# structlog minimum log level. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend (React / Vite)
# -----------------------------------------------------------------------------

# Base URL the React dashboard uses to call the FastAPI backend.
# Must be reachable from the user's browser — not from inside Docker.
# Example for local development: http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
